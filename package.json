{
  "name": "@llmhut/agentvm",
  "version": "0.2.3",
  "type": "module",
  "description": "The runtime your AI agents deserve. Process management, memory bus, tool routing, message passing, and scheduling for autonomous agents.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agentvm": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli/index.ts --format esm --dts --clean",
    "commit": "cz",
    "dev": "tsup src/index.ts src/cli/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "prepare": "husky",
    "coverage:check": "vitest run --coverage && node scripts/check-coverage.js"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [
    "ai",
    "agents",
    "llm",
    "runtime",
    "kernel",
    "multi-agent",
    "orchestration",
    "agentic",
    "langchain",
    "crewai",
    "autogen",
    "process-manager",
    "message-broker",
    "tool-routing"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/llmhut/agentvm"
  },
  "bugs": {
    "url": "https://github.com/llmhut/agentvm/issues"
  },
  "homepage": "https://llmhut.github.io/agentvm",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "nanoid": "^5.0.0"
  }
}
